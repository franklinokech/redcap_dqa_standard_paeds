# =============================================================================
# CIN Maternal DQA - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# REDCap Configuration
REDCAP_URL=https://your-redcap-server.com/api/
REDCAP_CIN_NEON_STANDARD_API_TOKEN=your_api_token_here

# Date Range for DQA (YYYY-MM-DD)
DQA_START_DATE=2025-09-08
DQA_END_DATE=2026-05-27

# Data Source (redcap or local)
DATA_SOURCE=redcap

# Optional: Local data file (if DATA_SOURCE=local)
# LOCAL_DATA_PATH=cin_neon/data/raw/neonatal_data.csv

# Docker Configuration
DUCKDB_MEMORY_LIMIT=8GB
DUCKDB_THREADS=4
